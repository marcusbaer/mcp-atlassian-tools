# Confluence Data Center/Server base URL (without trailing slash)
CONFLUENCE_BASE_URL=replace_with_confluence_url

# Confluence Personal Access Token (Bearer)
CONFLUENCE_BEARER_TOKEN=replace_with_token

# Optional comma-separated space keys to limit search/list operations
# CONFLUENCE_SPACES_FILTER=SPACE,TEAM

# Optional: disable TLS certificate verification for internal/self-signed certs
# CONFLUENCE_SSL_VERIFY=true
